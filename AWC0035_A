#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
typedef long double ld;
typedef vector<int> vi;
typedef vector<long long> vll;
typedef vector<pair<ll,ll>> vpll;
typedef vector<vector<ll>> vvll;
#define PB push_back
#define F first 
#define S second 

void PRINTVEC(vll vec){
    for(ll i=0;i<(ll)vec.size();i++){
        printf("%lld ",vec[i]);
    }
    printf("\n");
}

int main(){

    ll n,m;
    scanf("%lld %lld",&n,&m);

    ll i=0;

    vll w;
    while(i<n){

        ll a;
        scanf("%lld",&a);
        w.PB(a);
        i++;
    }

    
    ll j=0;
    
    while(j<m){
        ll u,v,g;
        scanf("%lld %lld %lld",&u,&v,&g);
        w[u-1]=w[u-1]-g;
        w[v-1]=w[v-1]+g;
        j++;
    }
    //PRINTVEC(w);

    ll k=0;
    ll t=0;
    ll idx=-1;
    while(k<n){
        if(w[k]>t){
            t=w[k];
            idx=k+1;
        }

        k++;
    }
    printf("%lld\n",idx);
    

    return 0;
}
