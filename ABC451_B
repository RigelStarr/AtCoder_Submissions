#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
typedef vector<int> vi;
typedef vector<long long> vll;
typedef vector<pair<ll,ll>> vpll;
typedef vector<vector<ll>> vvll;
#define PB push_back
#define F first 
#define S second 
#define NO printf("NO\n")
#define YES printf("YES\n")

void SCANVEC(vll &vec, ll n) {
    for(ll i = 0; i < n; i++) {
        ll a;
        scanf("%lld ", &a);
        vec.PB(a);
    }
}
void PRINTVEC(vll vec){
    for(ll i=0;i<vec.size();i++){
        printf("%lld\n",vec[i]);
    }
    printf("\n");
}

////////////////////////////////////////////////////////////////////////////


int main(){
    ll n,m;
    scanf("%lld %lld\n",&n,&m);

    vll dep(m,0);
    ll i=0;
    while(i<n){
        ll a,b;
        scanf("%lld %lld\n",&a,&b);
        dep[a-1]--;
        dep[b-1]++;
        i++;
    }
    PRINTVEC(dep);
    
}
