#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
typedef long double ld;
typedef vector<int> vi;
typedef vector<long long> vll;
typedef vector<pair<ll,ll>> vpll;
typedef vector<vector<ll>> vvll;
#define PB push_back
#define F first 
#define S second 

void SCANVEC(vll &vec, ll n) {
    for(ll i = 0; i < n; i++) {
        ll a;
        scanf("%lld ", &a);
        vec.PB(a);
    }
}
void PRINTVEC(vll vec){
    for(ll i=0;i<vec.size();i++){
        printf("%lld ",vec[i]);
    }
    printf("\n");
}

int main(){

    ll h,w,q;
    scanf("%lld %lld %lld\n",&h,&w,&q);

    ll i=0;
    while(i<q){
        ll a,b;
        scanf("%lld %lld\n",&a,&b);
        if(a==1){
            printf("%lld\n",b*w);
            h=h-b;
        }else{
            printf("%lld\n",b*h);
            w=w-b;
        }
        i++;
    }

    return 0;
}
